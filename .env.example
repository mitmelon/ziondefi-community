# ── RABBITMQ ────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=card_deployment_queue

# ── LAYERSWAP ───────────────────────────────────────────────────────────
LAYERSWAP_API_KEY=

# ── AWS Bedrock (Required for Agent System) ───────────────────────────────────
# Region where Amazon Nova Lite is available (us-east-1 recommended)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AGENT_BEDROCK_MODEL=us.amazon.nova-2-lite-v1:0

# ── Agent System ──────────────────────────────────────────────────────────────
# Set to "true" to auto-start all seeded agents on server boot
AGENT_AUTOSTART=false


# ── CoinGecko (Used by PriceOracle) ──────────────────────────────────────────
# Optional: leave blank to use free tier (60s cache) or add Pro key for 10s cache
COINGECKO_API_KEY=your_coingecko_pro_api_key