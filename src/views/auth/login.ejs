<%- include('../partials/auth/header') %>
<body class="bg-brandGray text-gray-900 font-sans antialiased min-h-screen flex flex-col">
  <nav class="sticky top-0 z-50 glass-panel border-b border-gray-200 px-6 py-4 flex justify-between items-center">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-brandBlack rounded-md flex items-center justify-center">
        <img src="<%= typeof root !== 'undefined' ? root : '' %>public/home/ui/images/logo/logo-white.png">
      </div>
      <span class="text-xl font-bold tracking-tight">ZionDefi</span>
    </div>
  </nav>
  <div id="view-login" class="flex-1 flex flex-col items-center justify-center p-6">
    <div class="max-w-md w-full text-center">
      <h1 class="text-4xl font-bold mb-4 tracking-tight">Financial Freedom, <br/> Abstracted.</h1>
      <p class="text-gray-500 mb-8 leading-relaxed">Create and manage your decentralized card with smart yielding and savings. Spend anywhere at any time.</p>
      <button id="open-wallet-btn"
              class="w-full bg-brandBlack text-white px-6 py-3.5 rounded-xl font-medium hover:bg-gray-800 transition-all duration-200 shadow-lg flex items-center justify-center gap-2 active:scale-95">
        <i class="ph-bold ph-wallet"></i> Connect Wallet
      </button>
    </div>
  </div>
  <input type="hidden" name="_csrf" id="csrf-token" value="<%= csrfToken %>">
  <div id="wallet-backdrop"></div>
  <div id="wallet-drawer" role="dialog" aria-modal="true" aria-label="Connect Wallet">
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 flex-shrink-0">
      <div>
        <h2 class="text-lg font-bold text-gray-900 tracking-tight m-0">Connect Wallet</h2>
        <p id="drawer-subtitle" class="text-xs text-gray-400 mt-0.5">Choose your Starknet wallet</p>
      </div>
      <button id="drawer-close-btn" aria-label="Close wallet drawer"
              class="w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-gray-900 transition border-0 cursor-pointer flex-shrink-0">
        <i class="ph-bold ph-x"></i>
      </button>
    </div>
    <div id="wallet-list" class="flex-1 overflow-y-auto p-4 pb-6 flex flex-col gap-2"></div>
  </div>
  <div id="status-overlay" role="dialog" aria-live="polite">
    <div id="s-icon-wrap" class="flex items-center justify-center min-h-[40px]"></div>
    <p id="s-title" class="text-white text-xl font-bold m-0 tracking-tight"></p>
    <p id="s-sub" class="text-white/65 text-sm m-0 max-w-xs leading-relaxed"></p>
    <button id="s-cancel" style="display:none;"
            class="mt-1 bg-white/10 border border-white/20 text-white rounded-xl px-6 py-2.5 cursor-pointer text-sm font-medium hover:bg-white/20 transition">Cancel</button>
  </div>
</body>
<%- include('../partials/auth/footer') %>