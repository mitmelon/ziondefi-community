<div class="flex-1 flex items-center justify-center p-6 animate__animated animate__slideInUp">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-slate-100 p-6 text-center">
        <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-slate-50 flex items-center justify-center" id="card-loader">
                <svg class="w-10 h-10 text-slate-700 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none"
                    viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-slate-900" id="card-deployed"><%= t('card.deploying') %></h2>
            <p class="text-sm text-slate-500" id="card-description"><%= t('card.deploying_desc') %></p>
            <div class="mt-3 flex items-center justify-center gap-3" id="card-status">
                <span class="text-xs text-slate-400"><%= t('card.deploying_working') %></span>
            </div>
        </div>
    </div>
</div>